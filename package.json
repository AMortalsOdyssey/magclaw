{
  "name": "magclaw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first blue pixel mission control for Codex-powered agent runs.",
  "scripts": {
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "test": "node scripts/test-runner.mjs quick",
    "test:quick": "node scripts/test-runner.mjs quick",
    "test:ui": "node scripts/test-runner.mjs ui",
    "test:flow": "node scripts/test-runner.mjs flow",
    "test:pg": "node scripts/test-runner.mjs pg",
    "test:all": "node scripts/test-runner.mjs all",
    "check": "node --check server/index.js",
    "cloud:db:init": "node server/cloud/postgres.js migrate",
    "cloud:db:status": "node server/cloud/postgres.js status",
    "web:start": "node server/index.js",
    "web:check": "node --check server/index.js",
    "web:docker:build": "docker build -f web/Dockerfile -t magclaw-web .",
    "daemon:pack": "npm pack --dry-run --json ./daemon",
    "daemon:publish": "node scripts/publish-daemon.mjs",
    "daemon:publish:dry-run": "node scripts/publish-daemon.mjs --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
