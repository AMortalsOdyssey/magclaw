# Copy this file to scripts/gemini-live.env.local, then fill the local paths.
# Keep both .env.local and *.local.json files out of git.

# Save your service account JSON somewhere local, for example:
# /absolute/path/to/gemini-live-service-account.local.json
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/gemini-live-service-account.local.json

GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# Current GA Live model on Vertex / Gemini Enterprise Agent Platform.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# Optional. Keep it short for latency tests.
GEMINI_LIVE_SYSTEM_INSTRUCTION=You are a concise, natural realtime voice assistant. Reply in the user's language.
