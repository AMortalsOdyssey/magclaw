# Copy this file to scripts/skyengine-realtime-agent.env.local and fill the key.
# Keep *.env.local and *.local files out of git.

SKYENGINE_API_KEY=
SKYENGINE_BASE_URL=https://model-api.skyengine.com.cn
SKYENGINE_REALTIME_MODEL=gpt-realtime-2.0
SKYENGINE_REALTIME_VOICE=sage
SKYENGINE_REALTIME_SPEED=1.04

# macOS ffmpeg avfoundation input. Run with --list-devices to inspect.
SKYENGINE_REALTIME_MIC_DEVICE=:0

# Optional. Set to none to disable input audio transcription requests.
SKYENGINE_REALTIME_INPUT_TRANSCRIPTION_MODEL=whisper-1

# Optional persona override.
# SKYENGINE_REALTIME_SYSTEM_PROMPT=
